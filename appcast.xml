<?xml version="1.0" encoding="utf-8"?>
<!--
    Afterwords Sparkle appcast.

    Items must be signed with Ed25519 against the SUPublicEDKey baked into
    Afterwords/Info.plist. See RELEASING.md for the sign_update workflow.

    Sparkle silently rejects items without a valid sparkle:edSignature, so
    an empty channel (no <item>s) is the correct state until a signed
    release is ready to publish.
-->
<rss version="2.0" xmlns:sparkle="http://www.andymatuschak.org/xml-namespaces/sparkle">
    <channel>
        <title>Afterwords</title>
        <link>https://raw.githubusercontent.com/adrianwedd/afterwords-app/main/appcast.xml</link>
        <description>Afterwords release notes</description>
        <language>en</language>
    </channel>
</rss>
